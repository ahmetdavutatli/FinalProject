<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/image_view_designer_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/text_view_designer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Designer Name"
            android:textSize="20sp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/image_view_design"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_launcher_background" />

    <TextView
        android:id="@+id/text_view_design_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Design Description"
        android:textSize="16sp" />

    <Button
        android:id="@+id/button_make_offer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Make Offer" />

</LinearLayout>
